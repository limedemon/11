@dp.message(AdminMobAdd.photo)
async def m_step_1(message: Message, state: FSMContext):
    if not message.photo: return await message.answer("⚠️ Нужно фото.")
    await state.update_data(photo=message.photo[-1].file_id)
    await state.set_state(AdminMobAdd.name)
    await message.answer("📝 Введите название моба:")

@dp.message(AdminMobAdd.name)
async def m_step_2(message: Message, state: FSMContext):
    await state.update_data(name=message.text.strip())
    await state.set_state(AdminMobAdd.hp)
    await message.answer("❤️ Введите здоровье (ХП):")

@dp.message(AdminMobAdd.hp)
async def m_step_3(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Число.")
    await state.update_data(hp=int(message.text))
    await state.set_state(AdminMobAdd.effect)
    await message.answer("✨ Выберите эффект:", reply_markup=get_mob_effect_kb())

@dp.callback_query(AdminMobAdd.effect, F.data.startswith("mob_eff_"))
async def m_step_4(callback: CallbackQuery, state: FSMContext):
    effect_name = callback.data.split("_")[2]
    
    if effect_name == "none":
        data = await state.get_data()
        global mob_id_counter
        mid = str(mob_id_counter)
        mobs_db[mid] = {"photo": data["photo"], "name": data["name"], "hp": data["hp"], "effect": "none", "defense_percent": 0}
        mob_id_counter += 1
        await state.clear()
        try: await callback.message.delete()
        except: pass
        await send_main_screen(message=callback.message, header_text=f"✅ Моб «{data['name']}» создан!")
        return await callback.answer()
        
    await state.update_data(effect="defense")
    await state.set_state(AdminMobAdd.defense_percent)
    await callback.message.edit_text("📉 Введите % защиты (от 0 до 99):")
    await callback.answer()

@dp.message(AdminMobAdd.defense_percent)
async def m_step_5(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Число.")
    data = await state.get_data()
    global mob_id_counter
    mid = str(mob_id_counter)
    mobs_db[mid] = {"photo": data["photo"], "name": data["name"], "hp": data["hp"], "effect": "defense", "defense_percent": int(message.text)}
    mob_id_counter += 1
    await state.clear()
    await send_main_screen(message, "✅ Моб с защитой успешно создан!")

