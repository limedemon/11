@router.callback_query(F.data == "menu_crates")
async def crates_list(call: CallbackQuery):
    await call.message.edit_text("📦 Выберите крейт:", reply_markup=await generate_items_kb("crates", "viewcrate"))

@router.callback_query(F.data.startswith("viewcrate_"))
async def crate_view(call: CallbackQuery):
    c_id = int(call.data.split("_")[1])
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT name FROM crates WHERE id = ?', (c_id,)) as cur:
            c_name = (await cur.fetchone())[0]
        async with db.execute('''
            SELECT u.name, ci.weight FROM crate_items ci 
            JOIN units u ON ci.unit_id = u.id WHERE ci.crate_id = ?
        ''', (c_id,)) as cur:
            items = await cur.fetchall()
            
    text = f"📦 <b>Крейт: {c_name}</b>\n\n" + "\n".join([f"- {n} (Вес: {w})" for n, w in items])
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="🎁 Открыть", callback_data=f"opencrate_{c_id}")],
        [InlineKeyboardButton(text="🔙 Назад", callback_data="menu_crates")]
    ])
    await call.message.edit_text(text, reply_markup=kb, parse_mode="HTML")

@router.callback_query(F.data.startswith("opencrate_"))
async def crate_open(call: CallbackQuery):
    c_id = int(call.data.split("_")[1])
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT unit_id, weight FROM crate_items WHERE crate_id = ?', (c_id,)) as cur:
            items = await cur.fetchall()
    
    if not items: return await call.answer("Пустой крейт!", show_alert=True)
    
    total = sum(w for _, w in items)
    rand = random.randint(1, total)
    curr = 0
    won_id = items[0][0]
    for uid, w in items:
        curr += w
        if rand <= curr:
            won_id = uid
            break
            
    async with aiosqlite.connect(DB_NAME) as db:
        await db.execute('INSERT INTO inventory (user_id, unit_id) VALUES (?, ?)', (call.from_user.id, won_id))
        async with db.execute('SELECT name FROM units WHERE id = ?', (won_id,)) as cur:
            u_name = (await cur.fetchone())[0]
        await db.commit()
        
    await call.answer(f"🎉 Выпало: {u_name}!", show_alert=True)
    await crates_list(call)

