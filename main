@dp.callback_query(StateFilter('*'), F.data == "admin_panel")
async def cq_admin_panel(callback: CallbackQuery, state: FSMContext):
    if str(callback.from_user.id) not in admins_db: return await callback.answer("⛔️ У вас нет прав!", show_alert=True)
    await state.clear()
    try: await callback.message.edit_text("👑 <b>Панель администратора</b>", reply_markup=get_admin_panel_kb())
    except:
        try: await callback.message.delete()
        except: pass
        msg = await callback.message.answer("👑 <b>Панель администратора</b>", reply_markup=get_admin_panel_kb())
        if callback.message.chat.type in {"group", "supergroup"}:
            panel_owners[f"{msg.chat.id}_{msg.message_id}"] = callback.from_user.id
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data == "admin_settings")
async def cq_admin_settings(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    text = (
        "⚙️ <b>Настройки бота</b>\n"
        "━━━━━━━━━━━━━━━\n"
        f"💰 Монет за 1 ед. урона: <b>{bot_settings['coins_per_damage']}</b>\n"
        f"⏩ Ход с авто-скипом: <b>{bot_settings['turn_time_skip']} сек.</b>\n"
        f"⏱ Ход без скипа: <b>{bot_settings['turn_time_noskip']} сек.</b>\n"
    )
    await callback.message.edit_text(text, reply_markup=get_settings_kb())
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("set_edit_"))
async def cq_set_edit(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    action = callback.data.split("_")[2]
    kb = InlineKeyboardMarkup(inline_keyboard=[[InlineKeyboardButton(text="🔙Отмена🔙", callback_data="admin_settings")]])
    if action == "coins":
        await state.set_state(AdminSettingsEdit.waiting_for_coins_per_damage)
        await callback.message.edit_text("💰 Введите количество монет за 1 ед. урона (можно дробное, например 0.5):", reply_markup=kb)
    elif action == "skip":
        await state.set_state(AdminSettingsEdit.waiting_for_turn_time_skip)
        await callback.message.edit_text("⏩ Введите время хода (в секундах) при Включенном авто-скипе:", reply_markup=kb)
    elif action == "noskip":
        await state.set_state(AdminSettingsEdit.waiting_for_turn_time_noskip)
        await callback.message.edit_text("⏱ Введите время хода (в секундах) при Выключенном авто-скипе:", reply_markup=kb)
    await callback.answer()

@dp.message(AdminSettingsEdit.waiting_for_coins_per_damage)
async def set_save_coins(message: Message, state: FSMContext):
    try:
        val = float(message.text.replace(",", "."))
        if val < 0: raise ValueError
    except ValueError:
        return await message.answer("⚠️ Ошибка! Введите положительное число.")
    bot_settings["coins_per_damage"] = val
    await state.clear()
    await message.answer("✅ Настройка сохранена!")
    await send_main_screen(message)

@dp.message(AdminSettingsEdit.waiting_for_turn_time_skip)
async def set_save_skip(message: Message, state: FSMContext):
    if not message.text.isdigit() or int(message.text) < 1:
        return await message.answer("⚠️ Ошибка! Введите целое число больше 0.")
    bot_settings["turn_time_skip"] = int(message.text)
    await state.clear()
    await message.answer("✅ Настройка сохранена!")
    await send_main_screen(message)

@dp.message(AdminSettingsEdit.waiting_for_turn_time_noskip)
async def set_save_noskip(message: Message, state: FSMContext):
    if not message.text.isdigit() or int(message.text) < 1:
        return await message.answer("⚠️ Ошибка! Введите целое число больше 0.")
    bot_settings["turn_time_noskip"] = int(message.text)
    await state.clear()
    await message.answer("✅ Настройка сохранена!")
    await send_main_screen(message)

