@dp.message(AdminMapAdd.photo)
async def map_step_0(message: Message, state: FSMContext):
    if not message.photo: return await message.answer("⚠️ ФОТО.")
    await state.update_data(photo=message.photo[-1].file_id)
    await state.set_state(AdminMapAdd.name)
    await message.answer("📝 Введите <b>название карты</b>:")

@dp.message(AdminMapAdd.name)
async def map_step_0_name(message: Message, state: FSMContext):
    await state.update_data(name=message.text.strip())
    await state.set_state(AdminMapAdd.starting_coins)
    await message.answer("💰 Введите начальные монеты:")

@dp.message(AdminMapAdd.starting_coins)
async def map_step_1(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Введите число.")
    await state.update_data(starting_coins=int(message.text))
    await state.set_state(AdminMapAdd.waves_count)
    await message.answer("🔢 Введите количество волн:")

@dp.message(AdminMapAdd.waves_count)
async def map_step_2(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Введите число.")
    await state.update_data(waves_total=int(message.text), current_wave=1, waves_list=[])
    await state.set_state(AdminMapAdd.mob_select)
    if not mobs_db:
        await state.clear()
        return await message.answer("⚠️ Сначала создайте мобов!")
    kb = [[InlineKeyboardButton(text=f"🔸{m.get('name', f'Моб №{mid}')}🔸", callback_data=f"mapmob_{mid}")] for mid, m in mobs_db.items()]
    await message.answer("🌊 <b>Волна 1.</b> Выберите моба:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))

@dp.callback_query(AdminMapAdd.mob_select, F.data.startswith("mapmob_"))
async def map_step_3(callback: CallbackQuery, state: FSMContext):
    await state.update_data(temp_mob=callback.data.split("_")[1])
    await state.set_state(AdminMapAdd.mobs_amount)
    await callback.message.edit_text("🔢 Введите количество мобов:")
    await callback.answer()

@dp.message(AdminMapAdd.mobs_amount)
async def map_step_4(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Введите число.")
    await state.update_data(temp_cnt=int(message.text))
    await state.set_state(AdminMapAdd.turns_count)
    await message.answer("⏱ Введите количество ходов:")

@dp.message(AdminMapAdd.turns_count)
async def map_step_5(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Введите число.")
    data = await state.get_data()
    data['waves_list'].append({"mob_id": data['temp_mob'], "count": data['temp_cnt'], "turns": int(message.text)})
    
    if data['current_wave'] < data['waves_total']:
        await state.update_data(waves_list=data['waves_list'], current_wave=data['current_wave']+1)
        await state.set_state(AdminMapAdd.mob_select)
        kb = [[InlineKeyboardButton(text=f"🔸{m.get('name', f'Моб №{mid}')}🔸", callback_data=f"mapmob_{mid}")] for mid, m in mobs_db.items()]
        await message.answer(f"🌊 <b>Волна {data['current_wave']+1}.</b> Выберите моба:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    else:
        await state.update_data(waves_list=data['waves_list'], rewards={})
        await state.set_state(AdminMapAdd.reward_select)
        kb = [[InlineKeyboardButton(text=f"🔸{c}🔸", callback_data=f"maprew_{idx}")] for idx, c in enumerate(currencies_db)]
        kb.append([InlineKeyboardButton(text="✅Готово (Сохранить)✅", callback_data="maprew_finish")])
        await message.answer("🎁 Выберите награду за победу:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))

@dp.callback_query(AdminMapAdd.reward_select, F.data.startswith("maprew_"))
async def map_step_6(callback: CallbackQuery, state: FSMContext):
    action = callback.data.split("_")[1]
    if action == "finish":
        data = await state.get_data()
        global map_id_counter
        mid = str(map_id_counter)
        maps_db[mid] = {"photo": data["photo"], "name": data["name"], "starting_coins": data["starting_coins"], "waves_total": data['waves_total'], "waves": data['waves_list'], "rewards": data['rewards']}
        map_id_counter += 1
        await state.clear()
        try: await callback.message.delete()
        except: pass
        await send_main_screen(callback.message, f"✅ Карта «{data['name']}» успешно создана!")
        return await callback.answer()
        
    await state.update_data(temp_cur=currencies_db[int(action)])
    await state.set_state(AdminMapAdd.reward_amount)
    await callback.message.edit_text("💰 Введите количество:")
    await callback.answer()

@dp.message(AdminMapAdd.reward_amount)
async def map_step_7(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Введите число.")
    data = await state.get_data()
    data['rewards'][data['temp_cur']] = int(message.text)
    await state.update_data(rewards=data['rewards'])
    await state.set_state(AdminMapAdd.reward_select)
    kb = [[InlineKeyboardButton(text=f"🔸{c}🔸", callback_data=f"maprew_{idx}")] for idx, c in enumerate(currencies_db)]
    kb.append([InlineKeyboardButton(text="✅Готово (Сохранить)✅", callback_data="maprew_finish")])
    await message.answer("🎁 Награда добавлена! Хотите добавить еще?", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))

@dp.callback_query(StateFilter('*'), F.data == "admin_del_map")
async def cq_admin_del_map(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    if not maps_db: return await callback.answer("⚠️ Карт нет!", show_alert=True)
    kb = [[InlineKeyboardButton(text=f"🗑{m.get('name', f'Карта №{mid}')}🗑", callback_data=f"delmap_{mid}")] for mid, m in maps_db.items()]
    await callback.message.edit_text("🗑 Выберите карту для удаления:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("delmap_"))
async def process_map_del(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    mid = callback.data.split("_")[1]
    if mid in maps_db:
        maps_db.pop(mid)
        await callback.message.edit_text("✅ Карта удалена!", reply_markup=get_admin_panel_kb())
    await callback.answer()

