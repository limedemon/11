@router.callback_query(F.data == "menu_play")
async def play_maps(call: CallbackQuery):
    await call.message.edit_text("🗺 Выберите карту:", reply_markup=await generate_items_kb("battles", "startbat"))

@router.callback_query(F.data.startswith("startbat_"))
async def bat_start_engine(call: CallbackQuery):
    b_id = int(call.data.split("_")[1])
    user_id = call.from_user.id
    
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT name FROM battles WHERE id = ?', (b_id,)) as cur:
            b_name = (await cur.fetchone())[0]
        async with db.execute('SELECT wave_number, mob_id, mob_count, turns_count FROM battle_waves WHERE battle_id = ? ORDER BY wave_number', (b_id,)) as cur:
            waves = await cur.fetchall()
        async with db.execute('''
            SELECT u.id, u.name, u.damage, u.cooldown, u.price, u.placement_limit 
            FROM inventory i JOIN units u ON i.unit_id = u.id 
            WHERE i.user_id = ? AND i.is_equipped = 1
        ''', (user_id,)) as cur:
            eq_units = await cur.fetchall()
        async with db.execute('SELECT currency_id, amount FROM battle_rewards WHERE battle_id = ?', (b_id,)) as cur:
            rewards = await cur.fetchall()

    if not eq_units: return await call.answer("❌ Экипируйте юнитов!", show_alert=True)
    if not waves: return await call.answer("❌ Нет волн в бою!", show_alert=True)

    # Инициализация боевой сессии
    active_battles[user_id] = {
        "b_name": b_name,
        "rewards": rewards,
        "waves": waves,
        "cur_wave": 0,
        "coins": 50.0,
        "placed": [],
        "inv": eq_units,
        "skip": False,
        "msg": call.message,
        "active": True,
        "last_text": "",
        "last_photo": None
    }
    await init_wave(user_id)

async def init_wave(uid: int):
    sess = active_battles.get(uid)
    if not sess or not sess["active"]: return
    
    w_data = sess["waves"][sess["cur_wave"]]
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT photo_id, hp FROM mobs WHERE id = ?', (w_data[1],)) as cur:
            m_data = await cur.fetchone()
            
    sess["m_photo"] = m_data[0]
    sess["m_hp"] = m_data[1] * w_data[2]
    sess["turns"] = w_data[3]
    for p in sess["placed"]: p["cd"] = 0
        
    await render_ui(uid)
    asyncio.create_task(turn_loop(uid))

async def render_ui(uid: int):
    sess = active_battles.get(uid)
    if not sess: return
    
    text = (
        f"⚔️ <b>{sess['b_name']}</b> | Волна {sess['cur_wave']+1}/{len(sess['waves'])}\n"
        f"❤️ ХП врагов: {sess['m_hp']}\n"
        f"⏳ Остаток ходов: {sess['turns']}\n"
        f"====================\n"
        f"💰 Монеты: {sess['coins']:.1f}\n"
        f"🛡 Поставлено: {len(sess['placed'])}"
    )
    
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="🛡 Поставить юнита", callback_data="bat_place")],
        [InlineKeyboardButton(text="⏩ Автоскип (5с)" if not sess["skip"] else "⏸ Обычный (20с)", callback_data="bat_skip")]
    ])
    
    if text == sess.get("last_text") and sess.get("last_photo") == sess["m_photo"]:
        return

    try:
        if sess["last_photo"] != sess["m_photo"]:
            await sess["msg"].delete()
            sess["msg"] = await bot.send_photo(chat_id=sess["msg"].chat.id, photo=sess["m_photo"], caption=text, reply_markup=kb, parse_mode="HTML")
            sess["last_photo"] = sess["m_photo"]
        else:
            await sess["msg"].edit_caption(caption=text, reply_markup=kb, parse_mode="HTML")
        sess["last_text"] = text
    except TelegramBadRequest as e:
        if "message is not modified" not in str(e): logging.error(e)

@router.callback_query(F.data == "bat_skip")
async def toggle_skip(call: CallbackQuery):
    sess = active_battles.get(call.from_user.id)
    if sess:
        sess["skip"] = not sess["skip"]
        sess["last_text"] = ""
        await render_ui(call.from_user.id)
    await call.answer()

@router.callback_query(F.data == "bat_place")
async def place_menu(call: CallbackQuery):
    sess = active_battles.get(call.from_user.id)
    if not sess: return await call.answer("Бой окончен")
    
    kb = []
    for u in sess["inv"]:
        cnt = sum(1 for p in sess["placed"] if p["id"] == u[0])
        kb.append([InlineKeyboardButton(text=f"{u[1]} | {u[4]}💰 | {cnt}/{u[5]}", callback_data=f"bplace_{u[0]}")])
    kb.append([InlineKeyboardButton(text="🔙 Назад в бой", callback_data="bat_back")])
    
    try:
        await call.message.edit_reply_markup(reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    except TelegramBadRequest: pass

@router.callback_query(F.data == "bat_back")
async def bat_back(call: CallbackQuery):
    sess = active_battles.get(call.from_user.id)
    if sess:
        sess["last_text"] = ""
        await render_ui(call.from_user.id)
    await call.answer()

@router.callback_query(F.data.startswith("bplace_"))
async def do_place(call: CallbackQuery):
    uid = int(call.data.split("_")[1])
    sess = active_battles.get(call.from_user.id)
    if not sess: return
    
    u_data = next((u for u in sess["inv"] if u[0] == uid), None)
    if not u_data: return
    
    cnt = sum(1 for p in sess["placed"] if p["id"] == uid)
    if sess["coins"] < u_data[4]: return await call.answer("❌ Нет монет!", show_alert=True)
    if cnt >= u_data[5]: return await call.answer("❌ Лимит юнитов!", show_alert=True)
        
    sess["coins"] -= u_data[4]
    sess["placed"].append({"id": uid, "dmg": u_data[2], "cd_max": u_data[3], "cd": 0})
    await call.answer("✅ Поставлен!")
    await place_menu(call)

async def turn_loop(uid: int):
    sess = active_battles.get(uid)
    if not sess or not sess["active"]: return
    
    while sess["turns"] > 0 and sess["m_hp"] > 0 and sess["active"]:
        await asyncio.sleep(5 if sess["skip"] else 20)
        if not sess["active"]: break
        
        dmg = 0
        for p in sess["placed"]:
            p["cd"] += 1
            if p["cd"] >= p["cd_max"]:
                dmg += p["dmg"]
                p["cd"] = 0
                
        sess["m_hp"] -= dmg
        if sess["m_hp"] < 0: sess["m_hp"] = 0
        sess["coins"] += dmg * 0.5
        sess["turns"] -= 1
        
        await render_ui(uid)
        
    if sess["m_hp"] <= 0:
        sess["cur_wave"] += 1
        if sess["cur_wave"] >= len(sess["waves"]): await finish_bat(uid, True)
        else: await init_wave(uid)
    elif sess["turns"] <= 0:
        await finish_bat(uid, False)

async def finish_bat(uid: int, win: bool):
    sess = active_battles.get(uid)
    if not sess: return
    sess["active"] = False
    
    res = "🎉 <b>ПОБЕДА!</b>\nНаграды:\n" if win else "💀 <b>ПОРАЖЕНИЕ (1/10 награды)</b>\nУтешительный приз:\n"
    
    async with aiosqlite.connect(DB_NAME) as db:
        for cur_id, amt in sess["rewards"]:
            final_amt = amt if win else max(1, amt // 10)
            await db.execute('''
                INSERT INTO user_currencies (user_id, currency_id, amount) 
                VALUES (?, ?, ?) ON CONFLICT(user_id, currency_id) DO UPDATE SET amount = amount + ?
            ''', (uid, cur_id, final_amt, final_amt))
            
            async with db.execute('SELECT symbol FROM currencies WHERE id = ?', (cur_id,)) as cur:
                sym = (await cur.fetchone())[0]
            res += f"- {final_amt} {sym}\n"
        await db.commit()
        
    try:
        await sess["msg"].edit_caption(caption=res, reply_markup=main_menu_kb(), parse_mode="HTML")
    except: pass
    del active_battles[uid]

# ==========================================
# ЗАПУСК БОТА
# ==========================================
async def main():
    await init_db()
    await bot.delete_webhook(drop_pending_updates=True)
    logging.info("Бот TOWER DEFENSE успешно запущен и готов к работе!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
