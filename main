@dp.message(AdminUnitAdd.supply_limit)
async def u_step_5_limit(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Число.")
    await state.update_data(supply_limit=int(message.text))
    await state.set_state(AdminUnitAdd.deploy_cost)
    await message.answer("💰 Введите цену в бою:")

@dp.message(AdminUnitAdd.deploy_cost)
async def u_step_6_cost(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("⚠️ Число.")
    await state.update_data(deploy_cost=int(message.text))
    data = await state.get_data()
    
    if data["unit_type"] == "Саппорт":
        await state.set_state(AdminUnitAdd.cd)
        await message.answer("⏱ Введите Буст КД (множитель, например 0.80):")
    elif data["unit_type"] == "Ферма":
        await state.update_data(cd=0)
        await state.set_state(AdminUnitAdd.damage)
        await message.answer("💰 Введите доход (монет за волну):")
    else:
        await state.set_state(AdminUnitAdd.cd)
        await message.answer("⏱ Введите КД (например 0.25 или 1):")

@dp.message(AdminUnitAdd.cd)
async def u_step_7_cd(message: Message, state: FSMContext):
    try: val = float(message.text.replace(",", "."))
    except: return await message.answer("⚠️ Введите число (например 0.5).")
    if val <= 0: return await message.answer("⚠️ Число должно быть больше 0.")
    
    data = await state.get_data()
    if data["unit_type"] == "Саппорт":
        await state.update_data(cd_boost=val)
        await state.set_state(AdminUnitAdd.damage)
        await message.answer("💥 Введите Буст Урона (множитель, например 1.5):")
    else:
        await state.update_data(cd=val)
        await state.set_state(AdminUnitAdd.damage)
        await message.answer("💥 Введите урон (число):")

@dp.message(AdminUnitAdd.damage)
async def u_step_8_damage(message: Message, state: FSMContext):
    data = await state.get_data()
    global unit_id_counter
    uid = str(unit_id_counter)
    
    u_dict = {
        "photo": data["photo"], 
        "name": data["name"], 
        "rarity": data["rarity"], 
        "unit_type": data["unit_type"], 
        "supply_limit": data["supply_limit"], 
        "deploy_cost": data["deploy_cost"]
    }
    
    if data["unit_type"] == "Саппорт":
        try: val = float(message.text.replace(",", "."))
        except: return await message.answer("⚠️ Введите число.")
        u_dict["cd_boost"] = data["cd_boost"]
        u_dict["dmg_boost"] = val
    elif data["unit_type"] == "Ферма":
        if not message.text.isdigit(): return await message.answer("⚠️ Целое число.")
        u_dict["cd"] = 0
        u_dict["damage"] = 0
        u_dict["income"] = int(message.text)
    else:
        if not message.text.isdigit(): return await message.answer("⚠️ Целое число.")
        u_dict["cd"] = data["cd"]
        u_dict["damage"] = int(message.text)
        
    units_db[uid] = u_dict
    unit_id_counter += 1
    await state.clear()
    await send_main_screen(message, f"✅ Юнит «{data['name']}» успешно создан!")

@dp.callback_query(StateFilter('*'), F.data == "admin_del_unit")
async def cq_u_del(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    if not units_db: return await callback.answer("⚠️ База юнитов пуста!", show_alert=True)
    kb = [[InlineKeyboardButton(text=f"🗑{u.get('name', f'Юнит №{uid}')}🗑", callback_data=f"delunit_{uid}")] for uid, u in units_db.items()]
    await callback.message.edit_text("🗑 Выберите юнита для удаления:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("delunit_"))
async def process_u_del(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    uid = callback.data.split("_")[1]
    if uid in units_db:
        units_db.pop(uid)
        await callback.message.edit_text("✅ Юнит удален!", reply_markup=get_admin_panel_kb())
    await callback.answer()

