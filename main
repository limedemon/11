    await state.clear()
    await send_main_screen(message, "✅ Валюта добавлена!")

@dp.callback_query(StateFilter('*'), F.data == "admin_del_cur")
async def cq_c_del(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    if not currencies_db: return await callback.answer("⚠️ Пусто!")
    kb = []
    for idx, c in enumerate(currencies_db):
        kb.append([InlineKeyboardButton(text=f"🗑{c}🗑", callback_data=f"delcur_{idx}")])
    await callback.message.edit_text("🗑 Выберите валюту для удаления:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("delcur_"))
async def process_c_del(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    idx = int(callback.data.split("_")[1])
    if currencies_db[idx] == "💰 Монеты":
        return await callback.answer("⚠️ Монеты нельзя удалить!", show_alert=True)
    if 0 <= idx < len(currencies_db):
        currencies_db.pop(idx)
        await callback.message.edit_text("✅ Валюта удалена!", reply_markup=get_admin_panel_kb())
    await callback.answer()

