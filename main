@router.message(AdminCurrency.symbol)
async def add_cur_finish(message: Message, state: FSMContext):
    async with aiosqlite.connect(DB_NAME) as db:
        try:
            await db.execute('INSERT INTO currencies (symbol) VALUES (?)', (message.text.strip(),))
            await db.commit()
            await message.answer("✅ Валюта добавлена.", reply_markup=main_menu_kb())
        except aiosqlite.IntegrityError:
            await message.answer("❌ Такая валюта уже существует.")
    await state.clear()

