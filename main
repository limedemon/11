@router.message(AdminUnit.cooldown)
async def add_unit_cooldown(message: Message, state: FSMContext):
    if not message.text.isdigit() or int(message.text) <= 0 or int(message.text) % 2 != 0:
        return await message.answer("❌ Только четное положительное число.")
    await state.update_data(cooldown=int(message.text))
    await message.answer("Введите урон юнита:", reply_markup=cancel_kb())
    await state.set_state(AdminUnit.damage)

