            except: pass
        else:
            try: await callback.bot.edit_message_caption(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], caption=text[:1024], reply_markup=main_kb, parse_mode="HTML")
            except:
                try: await callback.bot.edit_message_text(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], text=text[:4096], reply_markup=main_kb, parse_mode="HTML")
                except: pass
    except TelegramBadRequest: pass
    await callback.answer("Таймер изменен!")

@dp.callback_query(StateFilter('*'), F.data.startswith("b_surr_"))
async def cq_battle_surrender(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    battle_id = callback.data.split("_")[2]
    user_id_str = str(callback.from_user.id)
    
    if battle_id not in active_battles: return await callback.answer("Бой окончен.", show_alert=True)
    battle = active_battles[battle_id]
    if user_id_str not in battle["players"]: return await callback.answer("Вы не участвуете в этом бою!", show_alert=True)
        
    p_msg_id = battle["player_msg_ids"].get(user_id_str)
    if p_msg_id:
        try: await callback.bot.delete_message(chat_id=battle["chat_id"], message_id=p_msg_id)
        except: pass
        
    battle["players"].pop(user_id_str)
    if user_id_str in user_to_battle: del user_to_battle[user_id_str]
    
    m_data = maps_db[battle["map_id"]]
    rew = m_data.get("rewards", {})
    bal = user_balances.get(user_id_str, {"💰 Монеты": 100, "💎 Гемы": 0})
    text = "📛📛📛Сдался📛📛📛\n"
    for k, v in rew.items():
        amt = max(1, int(v * 0.1))
        bal[k] = bal.get(k, 0) + amt
        text += f"+{amt} {k}\n"
    user_balances[user_id_str] = bal
    
    try: await callback.bot.send_message(chat_id=battle["chat_id"], text=text)
    except: pass
    
    if not battle["players"]:
        await callback.bot.send_message(chat_id=battle["chat_id"], text="🏳 <b>Все игроки сдались.</b> Бой завершен.")
        await cleanup_battle(battle_id, callback.bot)
    else:
        photo_file, text, main_kb = render_battle_ui(battle_id)
        try: 
            if photo_file:
                try: await callback.bot.edit_message_media(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], media=InputMediaPhoto(media=photo_file, caption=text[:1024], parse_mode="HTML"), reply_markup=main_kb)
                except: pass
            else:
                try: await callback.bot.edit_message_caption(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], caption=text[:1024], reply_markup=main_kb, parse_mode="HTML")
                except:
                    try: await callback.bot.edit_message_text(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], text=text[:4096], reply_markup=main_kb, parse_mode="HTML")
                    except: pass
        except TelegramBadRequest: pass
        
    await callback.answer("Вы сдались.")

