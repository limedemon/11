# 🔧 АДМИНКА: МОДЕРАТОРЫ
# ==========================================
@router.callback_query(F.data == "adm_add_mod")
async def add_mod_start(call: CallbackQuery, state: FSMContext):
    await call.message.edit_text("Отправь ID пользователя, перешли его сообщение, или введи @username:", reply_markup=cancel_kb())
    await state.set_state(AdminMod.add_mod)

@router.message(AdminMod.add_mod)
async def add_mod_finish(message: Message, state: FSMContext):
    user_id = None
    if message.forward_origin:
        if hasattr(message.forward_origin, 'sender_user') and message.forward_origin.sender_user:
            user_id = message.forward_origin.sender_user.id
    elif message.text.isdigit():
        user_id = int(message.text)
    elif message.text.startswith("@"):
        username = message.text.replace("@", "")
        async with aiosqlite.connect(DB_NAME) as db:
            async with db.execute('SELECT user_id FROM users WHERE username = ?', (username,)) as cur:
                res = await cur.fetchone()
                if res: user_id = res[0]

    if not user_id:
        return await message.answer("❌ Не удалось определить ID. Попробуй отправить просто числовой ID.")

    async with aiosqlite.connect(DB_NAME) as db:
        await db.execute('INSERT OR IGNORE INTO moderators (user_id) VALUES (?)', (user_id,))
        await db.commit()
    await message.answer(f"✅ Пользователь {user_id} назначен модератором.", reply_markup=main_menu_kb())
    await state.clear()

@router.callback_query(F.data == "adm_del_mod")
async def del_mod_start(call: CallbackQuery, state: FSMContext):
    await call.message.edit_text("Отправь ID модератора для удаления:", reply_markup=cancel_kb())
    await state.set_state(AdminMod.del_mod)

@router.message(AdminMod.del_mod)
async def del_mod_finish(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("❌ Введите числовой ID.")
    async with aiosqlite.connect(DB_NAME) as db:
        await db.execute('DELETE FROM moderators WHERE user_id = ?', (int(message.text),))
        await db.commit()
    await message.answer("✅ Модератор удален.", reply_markup=main_menu_kb())
    await state.clear()

