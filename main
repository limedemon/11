# Админ: Управление админами
@dp.callback_query(StateFilter('*'), F.data == "admin_add")
async def cq_adm_add(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    await state.set_state(AdminStates.waiting_for_add)
    await callback.message.edit_text("👨‍💻 Введите ID нового администратора:")
    await callback.answer()

@dp.message(AdminStates.waiting_for_add)
async def process_adm_add(message: Message, state: FSMContext):
    uid = extract_user_identifier(message)
    if uid:
        admins_db.add(uid)
        await send_main_screen(message, f"✅ Пользователь {uid} добавлен в админы!")
    else:
        await message.answer("⚠️ Ошибка распознавания ID.")
    await state.clear()

@dp.callback_query(StateFilter('*'), F.data == "admin_remove")
async def cq_adm_rem(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    await state.set_state(AdminStates.waiting_for_remove)
    admins_list = "\n".join([f"• <code>{adm}</code>" for adm in admins_db])
    await callback.message.edit_text(f"🚫 <b>Текущие админы:</b>\n{admins_list}\n\nКого удалить? Введите ID:")
    await callback.answer()

@dp.message(AdminStates.waiting_for_remove)
async def process_adm_rem(message: Message, state: FSMContext):
    uid = extract_user_identifier(message)
    if uid and uid != MAIN_ADMIN_ID and uid in admins_db:
        admins_db.remove(uid)
        await send_main_screen(message, f"✅ Администратор {uid} удален!")
    else:
        await message.answer("⚠️ Ошибка. Пользователь не найден или это создатель.")
    await state.clear()

# ==========================================
# 7. УНИВЕРСАЛЬНЫЙ ПЕРЕХВАТЧИК (ОШИБКИ И НЕИЗВЕСТНЫЕ КОМАНДЫ)
# ==========================================
async def safe_exit_and_menu(message: Message, state: FSMContext, alert_text=None):
    await state.clear()
    user_id_str = str(message.from_user.id)
    
    battle_id = user_to_battle.get(user_id_str)
    if battle_id and battle_id in active_battles:
        battle = active_battles[battle_id]
        p_msg_id = battle["player_msg_ids"].get(user_id_str)
        if p_msg_id:
            try: await message.bot.delete_message(chat_id=battle["chat_id"], message_id=p_msg_id)
            except: pass
        battle["players"].pop(user_id_str, None)
        del user_to_battle[user_id_str]
        
        if not battle["players"]:
            if battle_id in active_tasks: active_tasks[battle_id].cancel()
            try: await message.bot.delete_message(chat_id=battle["chat_id"], message_id=battle["main_msg_id"])
            except: pass
            del active_battles[battle_id]
            
    init_user_balance(user_id_str)
    await send_main_screen(message, alert_text)

@dp.message(StateFilter('*'), F.text.startswith("/"))
async def handle_unknown_command(message: Message, state: FSMContext):
    await safe_exit_and_menu(message, state, "⚠️ Неизвестная команда. Возвращаю в меню.")

@dp.message(StateFilter('*'))
async def handle_any_text(message: Message, state: FSMContext):
    if message.chat.type in {"group", "supergroup"}:
        return
    await safe_exit_and_menu(message, state)

# ==========================================
# 8. ЗАПУСК БОТА И АВТОСОХРАНЕНИЕ
# ==========================================
async def auto_save_task():
    while True:
        await asyncio.sleep(60)  # Сохраняем раз в 60 секунд
        save_data()

async def main():
    logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(levelname)s - %(message)s")
    load_data()
    
    if IS_MAIN_BOT:
        bots = load_child_bots()
        for tkn, oid in bots.items():
            p = subprocess.Popen([sys.executable, __file__, tkn, oid])
            child_processes.append(p)
            
    bot = Bot(token=TOKEN, default=DefaultBotProperties(parse_mode=ParseMode.HTML))
    
    await bot.set_my_commands([
        BotCommand(command="addbot", description="Подключить своего бота"),
        BotCommand(command="getcrate", description="Открыть случайный крейт (только для групп)"),
        BotCommand(command="panel", description="Открыть меню (только для групп)"),
        BotCommand(command="start", description="Перезапустить бота")
    ])
    
    await bot.delete_webhook(drop_pending_updates=True)
    
    # Запускаем фоновую задачу автосохранения
    asyncio.create_task(auto_save_task())
    
    try:
        await dp.start_polling(bot)
    finally:
        save_data() # Сохраняем данные при выключении
        await bot.session.close()
        if IS_MAIN_BOT:
            for p in child_processes:
                p.terminate()

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        pass
