# 🎹 КЛАВИАТУРЫ
# ==========================================
def cancel_kb() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[[InlineKeyboardButton(text="❌ Отмена", callback_data="cancel")]])

def main_menu_kb() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="⚔️ Играть", callback_data="menu_play")],
        [InlineKeyboardButton(text="📦 Крейты", callback_data="menu_crates"), InlineKeyboardButton(text="🎒 Инвентарь", callback_data="menu_inventory")],
        [InlineKeyboardButton(text="🔧 Админ-панель", callback_data="admin_panel")]
    ])

def admin_panel_kb() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="➕ Добавить модера", callback_data="adm_add_mod"), InlineKeyboardButton(text="➖ Удалить модера", callback_data="adm_del_mod")],
        [InlineKeyboardButton(text="💰 Новая валюта", callback_data="adm_add_cur"), InlineKeyboardButton(text="👾 Создать моба", callback_data="adm_add_mob")],
        [InlineKeyboardButton(text="👤 Создать юнита", callback_data="adm_add_unit"), InlineKeyboardButton(text="📦 Создать крейт", callback_data="adm_add_crate")],
        [InlineKeyboardButton(text="🗺 Создать бой", callback_data="adm_add_battle")]
    ])

async def generate_items_kb(table: str, cb_prefix: str) -> InlineKeyboardMarkup:
    async with aiosqlite.connect(DB_NAME) as db:
        column = "symbol" if table == "currencies" else ("id" if table == "mobs" else "name")
        async with db.execute(f'SELECT id, {column} FROM {table}') as cur:
            items = await cur.fetchall()
    kb = [[InlineKeyboardButton(text=f"[{row[0]}] {row[1]}", callback_data=f"{cb_prefix}_{row[0]}")] for row in items]
    kb.append([InlineKeyboardButton(text="❌ Отмена", callback_data="cancel")])
    return InlineKeyboardMarkup(inline_keyboard=kb)

# ==========================================
# 🎮 ГЛАВНОЕ МЕНЮ И ПРОФИЛЬ
# ==========================================
@router.message(Command("start"))
async def start_cmd(message: Message, state: FSMContext):
    await state.clear()
    user_id = message.from_user.id
    username = message.from_user.username or "Без_юзернейма"
    
    async with aiosqlite.connect(DB_NAME) as db:
        await db.execute('INSERT OR REPLACE INTO users (user_id, username) VALUES (?, ?)', (user_id, username))
        await db.commit()
        
        # Собираем инфу о балансе пользователя
        async with db.execute('''
            SELECT c.symbol, uc.amount FROM user_currencies uc
            JOIN currencies c ON uc.currency_id = c.id WHERE uc.user_id = ?
        ''', (user_id,)) as cur:
            balances = await cur.fetchall()

    profile_text = f"👤 <b>Профиль игрока</b>\nID: <code>{user_id}</code>\nИмя: {message.from_user.first_name}\n\n<b>Баланс:</b>\n"
    if balances:
        for symbol, amount in balances:
            profile_text += f"- {amount} {symbol}\n"
    else:
        profile_text += "- Пусто\n"

    await message.answer(profile_text, reply_markup=main_menu_kb(), parse_mode="HTML")

@router.callback_query(F.data == "cancel")
async def cancel_handler(call: CallbackQuery, state: FSMContext):
    await state.clear()
    await call.message.edit_text("Действие отменено. Возврат в главное меню.", reply_markup=main_menu_kb())

@router.callback_query(F.data == "admin_panel")
async def admin_panel_handler(call: CallbackQuery):
    if await is_admin(call.from_user.id):
        await call.message.edit_text("🔧 <b>Админ-панель</b>\nВыберите действие:", reply_markup=admin_panel_kb(), parse_mode="HTML")
    else:
        await call.answer("❌ У вас нет прав!", show_alert=True)

