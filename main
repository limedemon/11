dp = Dispatcher()
dp.callback_query.middleware(PanelMiddleware())

@dp.message(StateFilter('*'), Command("addbot"))
async def cmd_addbot(message: Message, state: FSMContext):
    await state.clear()
    args = message.text.split(maxsplit=1)
    if len(args) < 2:
        return await message.answer("⚠️ Использование: /addbot <токен>")
    
    new_token = args[1].strip()
    owner_id = str(message.from_user.id)
    
    bots = load_child_bots()
    if new_token in bots:
        return await message.answer("⚠️ Этот бот уже подключен и запущен!")
        
    try:
        test_bot = Bot(token=new_token)
        me = await test_bot.get_me()
        await test_bot.session.close()
    except Exception as e:
        return await message.answer(f"❌ Ошибка токена. Бот не найден или токен неверный: {e}")
        
    save_child_bot(new_token, owner_id)
    p = subprocess.Popen([sys.executable, __file__, new_token, owner_id])
    
    if IS_MAIN_BOT:
        child_processes.append(p)
        
    await message.answer(f"✅ Бот @{me.username} успешно запущен!\nОн абсолютно пустой (нет карт, мобов, юнитов). Вы автоматически назначены главным администратором. Нажмите /start в нём.")

@dp.message(StateFilter('*'), Command("panel"), F.chat.type.in_({"group", "supergroup"}))
async def cmd_panel(message: Message, state: FSMContext):
    await state.clear()
    init_user_balance(str(message.from_user.id))
    msg = await message.answer(get_welcome_text(str(message.from_user.id), message.from_user.first_name), reply_markup=get_main_menu_kb(message.chat.type))
    panel_owners[f"{msg.chat.id}_{msg.message_id}"] = message.from_user.id

@dp.message(StateFilter('*'), Command("getcrate"), F.chat.type.in_({"group", "supergroup"}))
async def cmd_getcrate_group(message: Message, state: FSMContext):
    await state.clear()
    user_id_str = str(message.from_user.id)
    current_time = time.time()
    last_time = user_free_crate_times.get(user_id_str, 0.0)
    
    if current_time - last_time < 1800:
        remaining = int(1800 - (current_time - last_time))
        mins = remaining // 60
        secs = remaining % 60
        return await message.answer(f"⏳ <b>{message.from_user.first_name}</b>, следующий бесплатный крейт будет доступен через {mins} мин. {secs} сек.")
        
    if not crates_db: 
        return await message.answer("⚠️ В базе пока нет крейтов.")
    
    init_user_balance(user_id_str)
    
    cid = random.choice(list(crates_db.keys()))
    crate = crates_db[cid]
    if not crate.get("units"): 
        return await message.answer("⚠️ Выбранный случайный крейт пуст.")
    
    uids = list(crate["units"].keys())
    weights = list(crate["units"].values())
    result_uid = random.choices(uids, weights=weights, k=1)[0]
    
    if user_id_str not in user_inventory: 
        user_inventory[user_id_str] = set()
    user_inventory[user_id_str].add(result_uid)
    
    user_free_crate_times[user_id_str] = current_time
    
    u_name = units_db[result_uid].get("name", f"Юнит №{result_uid}") if result_uid in units_db else f"Юнит №{result_uid}"
    c_name = crate.get("name", f"Крейт №{cid}")
    
    text = f"🎉 <b>{message.from_user.first_name}</b> открыл бесплатный <b>{c_name}</b>!\n━━━━━━━━━━━━━━━\nВам выпало:\n• <b>{u_name}</b>"
    
    if crate.get("photo"): await message.answer_photo(photo=crate["photo"], caption=text)
    else: await message.answer(text)

@dp.message(StateFilter('*'), F.text.in_({"🔙 Назад", "🔙Назад🔙"}))
async def global_back_button(message: Message, state: FSMContext):
    await state.clear()
    user_id_str = str(message.from_user.id)
    battle_id = user_to_battle.get(user_id_str)
    if battle_id and battle_id in active_battles:
        battle = active_battles[battle_id]
        p_msg_id = battle["player_msg_ids"].get(user_id_str)
        if p_msg_id:
            try: await message.bot.delete_message(chat_id=battle["chat_id"], message_id=p_msg_id)
            except: pass
        battle["players"].pop(user_id_str, None)
        del user_to_battle[user_id_str]
        
        if not battle["players"]:
            if battle_id in active_tasks: active_tasks[battle_id].cancel()
            try: await message.bot.delete_message(chat_id=battle["chat_id"], message_id=battle["main_msg_id"])
            except: pass
            del active_battles[battle_id]
            
        await send_main_screen(message, "🏳 <b>Вы сбежали с поля боя.</b>")
        return
    init_user_balance(user_id_str)
    await send_main_screen(message)

@dp.message(StateFilter('*'), CommandStart())
async def cmd_start(message: Message, state: FSMContext):
    await state.clear()
    init_user_balance(str(message.from_user.id))
    await send_main_screen(message, "🔄 <i>Инициализация интерфейса...</i>")

# --- БЕСПЛАТНЫЙ КРЕЙТ (КНОПКА В МЕНЮ) ---
@dp.callback_query(StateFilter('*'), F.data == "free_crate")
async def cq_free_crate(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    user_id_str = str(callback.from_user.id)
    current_time = time.time()
    last_time = user_free_crate_times.get(user_id_str, 0.0)
    
    if current_time - last_time < 1800:
        remaining = int(1800 - (current_time - last_time))
        mins = remaining // 60
        secs = remaining % 60
        return await callback.answer(f"⏳ Следующий бесплатный крейт будет доступен через {mins} мин. {secs} сек.", show_alert=True)
        
    if not crates_db:
        return await callback.answer("⚠️ В базе пока нет крейтов.", show_alert=True)
        
    cid = random.choice(list(crates_db.keys()))
    crate = crates_db[cid]
    if not crate.get("units"):
        return await callback.answer("⚠️ Выбранный случайный крейт пуст.", show_alert=True)
        
    uids = list(crate["units"].keys())
    weights = list(crate["units"].values())
    result_uid = random.choices(uids, weights=weights, k=1)[0]
    
    if user_id_str not in user_inventory: 
        user_inventory[user_id_str] = set()
    user_inventory[user_id_str].add(result_uid)
    
    user_free_crate_times[user_id_str] = current_time
    
    u_name = units_db[result_uid].get("name", f"Юнит №{result_uid}") if result_uid in units_db else f"Юнит №{result_uid}"
    c_name = crate.get("name", f"Крейт №{cid}")
    
    text = f"🎁 <b>Вы открыли бесплатный крейт!</b>\n━━━━━━━━━━━━━━━\nСлучайно выбран: <b>{c_name}</b>\nВам выпало:\n• <b>{u_name}</b>"
    
    await callback.message.answer(text)
    await callback.answer("🎁 Бесплатный крейт открыт!")

