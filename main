@dp.callback_query(StateFilter('*'), F.data.startswith("inv_toggle_"))
async def cq_inv_toggle(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    uid = callback.data.split("_")[2]
    user_id_str = str(callback.from_user.id)
    equipped = user_equipped.get(user_id_str, [])
    
    if uid in equipped: equipped.remove(uid)
    else:
        if len(equipped) >= 5: return await callback.answer("⚠️ Максимум 5 юнитов!", show_alert=True)
        equipped.append(uid)
        
    user_equipped[user_id_str] = equipped
    text, kb = render_inventory(user_id_str)
    await callback.message.edit_text(text, reply_markup=kb)
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data == "main_index")
async def cq_main_index(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    unlocked = user_inventory.get(str(callback.from_user.id), set())
    if not units_db:
        await callback.answer()
        try: return await callback.message.edit_text("📭 Пусто.")
        except: return await callback.message.answer("📭 Пусто.")
            
    text = "📖 <b>Индекс Юнитов</b>\n━━━━━━━━━━━━━━━\n\n"
    for uid, unit in units_db.items():
        if uid in unlocked:
            text += f"✅ <b>{unit.get('name', f'Юнит №{uid}')}</b>\n{format_unit_stats(unit)}"
        else: text += "❓ <b>???</b>\n└ <i>Скрыто</i>\n\n"
            
    try: await callback.message.edit_text(text)
    except:
        try: await callback.message.delete()
        except: pass
        msg = await callback.message.answer(text)
        if callback.message.chat.type in {"group", "supergroup"}:
            panel_owners[f"{msg.chat.id}_{msg.message_id}"] = callback.from_user.id
    await callback.answer()

