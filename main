# 📊 БАЗА ДАННЫХ
# ==========================================
async def init_db():
    async with aiosqlite.connect(DB_NAME) as db:
        await db.executescript('''
            CREATE TABLE IF NOT EXISTS users (user_id INTEGER PRIMARY KEY, username TEXT);
            CREATE TABLE IF NOT EXISTS moderators (user_id INTEGER PRIMARY KEY);
            CREATE TABLE IF NOT EXISTS currencies (id INTEGER PRIMARY KEY AUTOINCREMENT, symbol TEXT NOT NULL UNIQUE);
            CREATE TABLE IF NOT EXISTS mobs (id INTEGER PRIMARY KEY AUTOINCREMENT, photo_id TEXT, hp INTEGER);
            CREATE TABLE IF NOT EXISTS units (
                id INTEGER PRIMARY KEY AUTOINCREMENT, photo_id TEXT, rarity TEXT, name TEXT,
                attack_type TEXT, cooldown INTEGER, damage INTEGER, placement_limit INTEGER, price INTEGER
            );
            CREATE TABLE IF NOT EXISTS crates (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT);
            CREATE TABLE IF NOT EXISTS crate_items (
                id INTEGER PRIMARY KEY AUTOINCREMENT, crate_id INTEGER, unit_id INTEGER, weight INTEGER
            );
            CREATE TABLE IF NOT EXISTS battles (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, wave_count INTEGER);
            CREATE TABLE IF NOT EXISTS battle_waves (
                id INTEGER PRIMARY KEY AUTOINCREMENT, battle_id INTEGER, wave_number INTEGER,
                mob_id INTEGER, mob_count INTEGER, turns_count INTEGER
            );
            CREATE TABLE IF NOT EXISTS battle_rewards (
                id INTEGER PRIMARY KEY AUTOINCREMENT, battle_id INTEGER, currency_id INTEGER, amount INTEGER
            );
            CREATE TABLE IF NOT EXISTS inventory (
                id INTEGER PRIMARY KEY AUTOINCREMENT, user_id INTEGER, unit_id INTEGER, is_equipped BOOLEAN DEFAULT 0
            );
            CREATE TABLE IF NOT EXISTS user_currencies (
                user_id INTEGER, currency_id INTEGER, amount INTEGER DEFAULT 0,
                PRIMARY KEY (user_id, currency_id)
            );
        ''')
        await db.commit()

async def is_admin(user_id: int) -> bool:
    """Проверка прав. Первый вызвавший функцию становится главным админом."""
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT COUNT(*) FROM moderators') as cur:
            mod_count = (await cur.fetchone())[0]
        
        if mod_count == 0:
            await db.execute('INSERT INTO moderators (user_id) VALUES (?)', (user_id,))
            await db.commit()
            logging.info(f"Пользователь {user_id} назначен создателем/первым админом.")
            return True
            
        async with db.execute('SELECT 1 FROM moderators WHERE user_id = ?', (user_id,)) as cur:
            return bool(await cur.fetchone())

# ==========================================
# 📝 МАШИНЫ СОСТОЯНИЙ (FSM)
# ==========================================
class AdminMod(StatesGroup): add_mod = State(); del_mod = State()
class AdminCurrency(StatesGroup): symbol = State()
class AdminMob(StatesGroup): photo = State(); hp = State()
class AdminUnit(StatesGroup): photo = State(); rarity = State(); name = State(); attack_type = State(); cooldown = State(); damage = State(); placement_limit = State(); price = State()
class AdminCrate(StatesGroup): name = State(); select_unit = State(); unit_weight = State()
class AdminBattle(StatesGroup): 
    name = State()
    wave_count = State()
    wave_mob = State()
    wave_mob_count = State()
    wave_turns = State()
    rewards_menu = State()
    reward_amount = State()

# Хранилище сессий боев
