@router.message(AdminBattle.name)
async def bat_waves(message: Message, state: FSMContext):
    await state.update_data(name=message.text, waves_data=[], rewards_data=[])
    await message.answer("Введите кол-во волн:", reply_markup=cancel_kb())
    await state.set_state(AdminBattle.wave_count)

@router.message(AdminBattle.wave_count)
async def bat_wave_init(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("❌ Число.")
    await state.update_data(wave_count=int(message.text), current_wave=1)
    await message.answer("Волна 1. Выберите моба:", reply_markup=await generate_items_kb("mobs", "addbatmob"))
    await state.set_state(AdminBattle.wave_mob)

@router.callback_query(AdminBattle.wave_mob, F.data.startswith("addbatmob_"))
async def bat_wave_mob(call: CallbackQuery, state: FSMContext):
    data = await state.get_data()
    data['waves_data'].append({"mob_id": int(call.data.split("_")[1])})
    await state.update_data(waves_data=data['waves_data'])
    await call.message.edit_text(f"Волна {data['current_wave']}. Введите кол-во мобов:", reply_markup=cancel_kb())
    await state.set_state(AdminBattle.wave_mob_count)

@router.message(AdminBattle.wave_mob_count)
async def bat_wave_count(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("❌ Число.")
    data = await state.get_data()
    data['waves_data'][-1]['mob_count'] = int(message.text)
    await state.update_data(waves_data=data['waves_data'])
    await message.answer(f"Волна {data['current_wave']}. Введите кол-во ходов:", reply_markup=cancel_kb())
    await state.set_state(AdminBattle.wave_turns)

@router.message(AdminBattle.wave_turns)
async def bat_wave_turns(message: Message, state: FSMContext):
    if not message.text.isdigit(): return await message.answer("❌ Число.")
    data = await state.get_data()
    data['waves_data'][-1]['turns_count'] = int(message.text)
    
    if data['current_wave'] < data['wave_count']:
        data['current_wave'] += 1
        await state.update_data(current_wave=data['current_wave'], waves_data=data['waves_data'])
        await message.answer(f"Волна {data['current_wave']}. Выберите моба:", reply_markup=await generate_items_kb("mobs", "addbatmob"))
        await state.set_state(AdminBattle.wave_mob)
    else:
        await state.update_data(waves_data=data['waves_data'])
        await show_rewards_menu(message, state)

async def show_rewards_menu(message_or_call, state: FSMContext):
    """Показывает меню выбора наград с возможностью сброса и завершения."""
    data = await state.get_data()
    rewards_text = "<b>Выбранные награды:</b>\n"
    if data['rewards_data']:
        for r in data['rewards_data']:
            rewards_text += f"- {r['amount']} {r['symbol']}\n"
    else:
        rewards_text += "- Пока нет\n"

    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT id, symbol FROM currencies') as cur:
            currencies = await cur.fetchall()
            
    kb = [[InlineKeyboardButton(text=f"Добавить {c[1]}", callback_data=f"addbatcur_{c[0]}_{c[1]}")] for c in currencies]
    kb.append([InlineKeyboardButton(text="🔄 Сбросить валюты", callback_data="bat_reset_rewards")])
    if data['rewards_data']:
        kb.append([InlineKeyboardButton(text="✅ Завершить создание", callback_data="bat_finish_creation")])
    kb.append([InlineKeyboardButton(text="❌ Отмена", callback_data="cancel")])

    text = f"Настройка наград за бой.\n\n{rewards_text}\nВыберите валюту для добавления:"
    markup = InlineKeyboardMarkup(inline_keyboard=kb)
    
    if isinstance(message_or_call, Message):
        await message_or_call.answer(text, reply_markup=markup, parse_mode="HTML")
    else:
        await message_or_call.message.edit_text(text, reply_markup=markup, parse_mode="HTML")
    await state.set_state(AdminBattle.rewards_menu)

@router.callback_query(AdminBattle.rewards_menu, F.data.startswith("addbatcur_"))
async def bat_reward_cur(call: CallbackQuery, state: FSMContext):
    _, cur_id, cur_symbol = call.data.split("_")
    await state.update_data(current_reward_id=int(cur_id), current_reward_symbol=cur_symbol)
    await call.message.edit_text(f"Введите количество для {cur_symbol} (четное, >0):", reply_markup=cancel_kb())
    await state.set_state(AdminBattle.reward_amount)

@router.message(AdminBattle.reward_amount)
async def bat_reward_amount(message: Message, state: FSMContext):
    if not message.text.isdigit() or int(message.text) <= 0 or int(message.text) % 2 != 0:
        return await message.answer("❌ Четное положительное число.")
    data = await state.get_data()
    data['rewards_data'].append({
        "currency_id": data['current_reward_id'],
        "symbol": data['current_reward_symbol'],
        "amount": int(message.text)
    })
    await state.update_data(rewards_data=data['rewards_data'])
    await show_rewards_menu(message, state)

@router.callback_query(AdminBattle.rewards_menu, F.data == "bat_reset_rewards")
async def bat_reset_rewards(call: CallbackQuery, state: FSMContext):
    await state.update_data(rewards_data=[])
    await show_rewards_menu(call, state)

@router.callback_query(AdminBattle.rewards_menu, F.data == "bat_finish_creation")
async def bat_finish_all(call: CallbackQuery, state: FSMContext):
    data = await state.get_data()
    async with aiosqlite.connect(DB_NAME) as db:
        cur = await db.execute('INSERT INTO battles (name, wave_count) VALUES (?, ?)', (data['name'], data['wave_count']))
        battle_id = cur.lastrowid
        for i, w in enumerate(data['waves_data']):
            await db.execute('INSERT INTO battle_waves (battle_id, wave_number, mob_id, mob_count, turns_count) VALUES (?, ?, ?, ?, ?)',
                             (battle_id, i+1, w['mob_id'], w['mob_count'], w['turns_count']))
        for r in data['rewards_data']:
            await db.execute('INSERT INTO battle_rewards (battle_id, currency_id, amount) VALUES (?, ?, ?)',
                             (battle_id, r['currency_id'], r['amount']))
        await db.commit()
        
    await call.message.edit_text("✅ Бой и все волны успешно созданы!", reply_markup=main_menu_kb())
    await state.clear()

