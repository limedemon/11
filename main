@dp.callback_query(StateFilter('*'), F.data == "crates_list")
async def cq_crates_list(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    if not crates_db: return await callback.answer("Крейтов пока нет!", show_alert=True)
    kb = [[InlineKeyboardButton(text=f"📦{c.get('name', f'Крейт №{cid}')} | {c['price']} {c.get('currency', '💰 Монеты')}📦", callback_data=f"crate_info_{cid}")] for cid, c in crates_db.items()]
    await callback.message.edit_text("📦 <b>Магазин Крейтов</b>\n━━━━━━━━━━━━━━━\n👇 Выберите крейт:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("crate_info_"))
async def cq_crate_info(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    cid = callback.data.split("_")[2]
    crate = crates_db[cid]
    unlocked = user_inventory.get(str(callback.from_user.id), set())
    total_weight = sum(crate["units"].values())
    
    req_cur = crate.get('currency', '💰 Монеты')
    text = f"📦 <b>{crate.get('name', f'Крейт №{cid}')}</b>\n━━━━━━━━━━━━━━━\n💰 <b>Цена:</b> {crate['price']} {req_cur}\n\n🎲 <b>Шансы:</b>\n"
    for uid, weight in crate["units"].items():
        if uid not in units_db: continue
        chance = (weight / total_weight) * 100
        text += f"• <b>{units_db[uid].get('name', f'Юнит №{uid}') if uid in unlocked else '???'}</b> - {chance:.2f}%\n"
    text += "━━━━━━━━━━━━━━━\nСколько открыть?"
    
    kb = [[InlineKeyboardButton(text="📦1📦", callback_data=f"crate_open_{cid}_1"), InlineKeyboardButton(text="📦5📦", callback_data=f"crate_open_{cid}_5")],
          [InlineKeyboardButton(text="📦10📦", callback_data=f"crate_open_{cid}_10"), InlineKeyboardButton(text="📦50📦", callback_data=f"crate_open_{cid}_50")],
          [InlineKeyboardButton(text="📦100📦", callback_data=f"crate_open_{cid}_100")]]
    
    try: await callback.message.delete()
    except: pass
    msg = await callback.message.answer_photo(photo=crate["photo"], caption=text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    if callback.message.chat.type in {"group", "supergroup"}:
        panel_owners[f"{msg.chat.id}_{msg.message_id}"] = callback.from_user.id
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("crate_open_"))
async def cq_crate_open(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    parts = callback.data.split("_")
    cid = parts[2]
    amount = int(parts[3])
    crate = crates_db[cid]
    user_id_str = str(callback.from_user.id)
    
    total_cost = crate["price"] * amount
    req_cur = crate.get("currency", "💰 Монеты")
    bal = user_balances.get(user_id_str, {"💰 Монеты": 100, "💎 Гемы": 0})
    
    if bal.get(req_cur, 0) < total_cost:
        return await callback.answer(f"Недостаточно валюты! Нужно {total_cost} {req_cur}.", show_alert=True)
        
    bal[req_cur] -= total_cost
    user_balances[user_id_str] = bal
    results = random.choices(list(crate["units"].keys()), weights=list(crate["units"].values()), k=amount)
    
    counts = {}
    if user_id_str not in user_inventory: user_inventory[user_id_str] = set()
    for uid in results:
        counts[uid] = counts.get(uid, 0) + 1
        user_inventory[user_id_str].add(uid)
    
    text = f"🎉 <b>{callback.from_user.first_name}</b> открыл <b>{crate.get('name', f'Крейт №{cid}')}</b> ({amount} шт.)!\n━━━━━━━━━━━━━━━\nВам выпало:\n\n"
    for uid, cnt in counts.items():
        if uid in units_db: text += f"• {units_db[uid].get('name', f'Юнит №{uid}')} (x{cnt})\n"
            
    await callback.message.answer(text)
    await callback.answer("Открыто!")

