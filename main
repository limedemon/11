@dp.callback_query(StateFilter('*'), F.data.startswith("battle_map_info_"))
async def cq_battle_map_info(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    mid = callback.data.split("_")[3]
    m_data = maps_db[mid]
    rew = "\n".join([f"• {k}: {v}" for k, v in m_data.get('rewards', {}).items()]) if m_data.get('rewards') else "Нет"
    text = f"🗺 <b>{m_data.get('name', f'Карта №{mid}')}</b>\n━━━━━━━━━━━━━━━\n💰 Старт: {m_data.get('starting_coins', 100)}\n🌊 Волн: {m_data.get('waves_total', 0)}\n🎁 Награды:\n{rew}\n\n👥 <b>Выберите макс. игроков в лифте:</b>"
    
    kb = [
        [InlineKeyboardButton(text="🛗1🛗", callback_data=f"el_create_{mid}_1"), InlineKeyboardButton(text="🛗2🛗", callback_data=f"el_create_{mid}_2")],
        [InlineKeyboardButton(text="🛗3🛗", callback_data=f"el_create_{mid}_3"), InlineKeyboardButton(text="🛗4🛗", callback_data=f"el_create_{mid}_4")]
    ]
    
    try: await callback.message.delete()
    except: pass
    msg = await callback.message.answer(text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    if callback.message.chat.type in {"group", "supergroup"}:
        panel_owners[f"{msg.chat.id}_{msg.message_id}"] = callback.from_user.id
    await callback.answer()

@dp.callback_query(StateFilter('*'), F.data.startswith("el_create_"))
async def cq_el_create(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    _, _, mid, max_p = callback.data.split("_")
    max_p = int(max_p)
    user_id_str = str(callback.from_user.id)
    
    if user_to_battle.get(user_id_str) or any(user_id_str in el["players"] for el in elevators_db.values()):
        return await callback.answer("Вы уже в бою или в лифте!", show_alert=True)
        
    global elevator_id_counter
    el_id = str(elevator_id_counter)
    elevator_id_counter += 1
    
    elevators_db[el_id] = {
        "map_id": mid,
        "max_p": max_p,
        "creator_id": user_id_str,
        "players": {user_id_str: callback.from_user.first_name}
    }
    
    m_name = maps_db[mid].get('name', f'Карта №{mid}')
    text = f"🛗 <b>Лифт: {m_name}</b>\nИгроки (1/{max_p}):\n• {callback.from_user.first_name}\n\nОжидание игроков..."
    
    kb = [[InlineKeyboardButton(text="🛗Вступить🛗", callback_data=f"el_join_{el_id}")]]
    kb.append([InlineKeyboardButton(text="▶️Начать досрочно▶️", callback_data=f"el_start_{el_id}")])
    kb.append([InlineKeyboardButton(text="❌Отменить❌", callback_data=f"el_cancel_{el_id}")])
    
    try: await callback.message.delete()
    except: pass
    await callback.message.answer(text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
    await callback.answer("Лифт создан!")

@dp.callback_query(StateFilter('*'), F.data.startswith("el_join_"))
async def cq_el_join(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    el_id = callback.data.split("_")[2]
    user_id_str = str(callback.from_user.id)
    
    if el_id not in elevators_db: return await callback.answer("Этот лифт уже отправлен или отменен!", show_alert=True)
    if user_to_battle.get(user_id_str) or any(user_id_str in el["players"] for el in elevators_db.values()):
        return await callback.answer("Вы уже в бою или в другом лифте!", show_alert=True)
    if not user_equipped.get(user_id_str, []):
        return await callback.answer("Экипируйте юнитов в инвентаре!", show_alert=True)
        
    el = elevators_db[el_id]
    el["players"][user_id_str] = callback.from_user.first_name
    
    if len(el["players"]) >= el["max_p"]:
        await start_multiplayer_battle(el_id, callback.message, callback.bot)
        await callback.answer("Лифт заполнен, начинаем!")
    else:
        m_name = maps_db[el["map_id"]].get('name', f'Карта №{el["map_id"]}')
        text = f"🛗 <b>Лифт: {m_name}</b>\nИгроки ({len(el['players'])}/{el['max_p']}):\n"
        for uid, name in el["players"].items(): text += f"• {name}\n"
        text += "\nОжидание игроков..."
        
        kb = [[InlineKeyboardButton(text="🛗Вступить🛗", callback_data=f"el_join_{el_id}")]]
        kb.append([InlineKeyboardButton(text="▶️Начать досрочно▶️", callback_data=f"el_start_{el_id}")])
        kb.append([InlineKeyboardButton(text="❌Отменить❌", callback_data=f"el_cancel_{el_id}")])
        
        try: await callback.message.edit_text(text, reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))
        except TelegramBadRequest: pass
        await callback.answer("Вы присоединились!")

@dp.callback_query(StateFilter('*'), F.data.startswith("el_start_"))
async def cq_el_start(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    el_id = callback.data.split("_")[2]
    if el_id not in elevators_db: return await callback.answer("Лифт не найден!")
    if elevators_db[el_id]["creator_id"] != str(callback.from_user.id): return await callback.answer("Только создатель может начать досрочно!", show_alert=True)
    await start_multiplayer_battle(el_id, callback.message, callback.bot)
    await callback.answer("Начинаем!")

@dp.callback_query(StateFilter('*'), F.data.startswith("el_cancel_"))
async def cq_el_cancel(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    el_id = callback.data.split("_")[2]
    if el_id not in elevators_db: return await callback.answer("Лифт не найден!")
    if elevators_db[el_id]["creator_id"] != str(callback.from_user.id): return await callback.answer("Только создатель может отменить!", show_alert=True)
    del elevators_db[el_id]
    try: await callback.message.delete()
    except: pass
    await callback.message.answer("Лифт отменен.")
    await callback.answer()

async def start_multiplayer_battle(el_id: str, message: Message, bot: Bot):
    el = elevators_db.pop(el_id)
    mid = el["map_id"]
    m_data = maps_db[mid]
    
    global battle_id_counter
    battle_id = str(battle_id_counter)
    battle_id_counter += 1
    
    players_data = {}
    for uid, name in el["players"].items():
        user_to_battle[uid] = battle_id
        players_data[uid] = {
            "name": name,
            "coins": float(m_data.get("starting_coins", 100)),
            "deployed": []
        }
        
    active_battles[battle_id] = {
        "map_id": mid,
        "current_wave": 1,
        "current_turn": 1,
        "base_hp": 100.0,
        "auto_skip": False,
        "mobs": [],
        "players": players_data,
        "chat_id": message.chat.id,
        "main_msg_id": None,
        "player_msg_ids": {}
    }
    
    w_info = m_data["waves"][0]
    mob = mobs_db.get(w_info["mob_id"], {"hp": 100})
    active_battles[battle_id]["mobs"] = [mob["hp"] for _ in range(w_info["count"])]
    
    photo_file, text, main_kb = render_battle_ui(battle_id)
    try: await message.delete()
    except: pass
    
    if photo_file: msg = await message.answer_photo(photo=photo_file, caption=text[:1024], reply_markup=main_kb, parse_mode="HTML")
    else: msg = await message.answer(text, reply_markup=main_kb, parse_mode="HTML")
    
    active_battles[battle_id]["main_msg_id"] = msg.message_id
    
    for uid, p in players_data.items():
        p_kb = get_player_kb(battle_id, uid)
        p_msg = await message.answer(f"👤 Юниты игрока <b>{p['name']}</b>:", reply_markup=p_kb)
        active_battles[battle_id]["player_msg_ids"][uid] = p_msg.message_id
    
    active_tasks[battle_id] = asyncio.create_task(battle_ticker(battle_id, bot))

async def cleanup_battle(battle_id: str, bot: Bot):
    battle = active_battles.get(battle_id)
    if not battle: return
    chat_id = battle["chat_id"]
    try: await bot.delete_message(chat_id=chat_id, message_id=battle["main_msg_id"])
    except: pass
    for p_msg_id in battle["player_msg_ids"].values():
        try: await bot.delete_message(chat_id=chat_id, message_id=p_msg_id)
        except: pass
    
    for p_uid in list(battle["players"].keys()):
        if p_uid in user_to_battle: del user_to_battle[p_uid]
    
    if battle_id in active_tasks: active_tasks[battle_id].cancel()
    del active_battles[battle_id]

async def process_battle_turn(battle_id: str, bot: Bot):
    if battle_id not in active_battles: return
    battle = active_battles[battle_id]
    m_data = maps_db[battle["map_id"]]
    w_info = m_data["waves"][battle["current_wave"] - 1]
    m_stats = mobs_db.get(w_info["mob_id"], {"effect": "none", "defense_percent": 0})
    m_def = m_stats.get("defense_percent", 0) if m_stats.get("effect") == "defense" else 0
    
    best_cd_mult = 1.0
    best_dmg_mult = 1.0
    
    for uid, p in battle["players"].items():
        for dep in p["deployed"]:
            if dep["uid"] in units_db:
                u_stats = units_db[dep["uid"]]
                if u_stats.get("unit_type") == "Саппорт":
                    cd_b = float(u_stats.get("cd_boost", 1.0))
                    dmg_b = float(u_stats.get("dmg_boost", 1.0))
                    if cd_b < best_cd_mult: best_cd_mult = cd_b
                    if dmg_b > best_dmg_mult: best_dmg_mult = dmg_b

    for uid, p in battle["players"].items():
        for dep in p["deployed"]:
            if not battle["mobs"]: break 
            if dep["uid"] not in units_db: continue
            u_stats = units_db[dep["uid"]]
            if u_stats.get("unit_type") in ["Саппорт", "Ферма"]: continue 
            
            base_cd = float(u_stats.get("cd", 1.0))
            actual_cd = round(base_cd * best_cd_mult, 2)
            if actual_cd <= 0.01: actual_cd = 0.01
            
            base_dmg = float(u_stats.get("damage", 10))
            actual_dmg = round(base_dmg * best_dmg_mult, 2)
            dmg = round(actual_dmg * (1 - m_def / 100), 2)
            
            dep["time_bank"] = dep.get("time_bank", 0.0) + 1.0
            
            while dep["time_bank"] >= actual_cd and battle["mobs"]:
                dep["time_bank"] -= actual_cd
                utype = u_stats.get("unit_type", u_stats.get("attack_type"))
                
                coins_earned = 0.0

                if utype == "Одиночный": 
                    actual_dmg_done = min(battle["mobs"][0], dmg)
                    coins_earned += actual_dmg_done * bot_settings["coins_per_damage"]
                    battle["mobs"][0] = round(battle["mobs"][0] - dmg, 2)
                    if battle["mobs"][0] <= 0: battle["mobs"].pop(0)
                elif utype == "Сплеш":
                    for i in range(min(5, len(battle["mobs"]))):
                        actual_dmg_done = min(battle["mobs"][i], dmg)
                        coins_earned += actual_dmg_done * bot_settings["coins_per_damage"]
                        battle["mobs"][i] = round(battle["mobs"][i] - dmg, 2)
                    battle["mobs"] = [h for h in battle["mobs"] if h > 0]
                elif utype == "АОЕ":
                    for i in range(len(battle["mobs"]))[:10]:
                        actual_dmg_done = min(battle["mobs"][i], dmg)
                        coins_earned += actual_dmg_done * bot_settings["coins_per_damage"]
                        battle["mobs"][i] = round(battle["mobs"][i] - dmg, 2)
                    battle["mobs"] = [h for h in battle["mobs"] if h > 0]
                
                p["coins"] += coins_earned

    chat_id = battle["chat_id"]

    if not battle["mobs"]:
        for p_uid, p_data in battle["players"].items():
            wave_income = 0
            for dep in p_data["deployed"]:
                u_st = units_db.get(dep["uid"], {})
                if u_st.get("unit_type") == "Ферма":
                    wave_income += u_st.get("income", 0)
            if wave_income > 0:
                p_data["coins"] += wave_income

        battle["current_wave"] += 1
        battle["current_turn"] = 1
        if battle["current_wave"] > m_data["waves_total"]:
            rew = m_data.get("rewards", {})
            text = "❇️❇️❇️Победа❇️❇️❇️\n"
            for k, v in rew.items():
                text += f"+{v} {k}\n"
                
            for p_uid in list(battle["players"].keys()):
                bal = user_balances.get(p_uid, {"💰 Монеты": 100, "💎 Гемы": 0})
                for k, v in rew.items(): bal[k] = bal.get(k, 0) + v
                user_balances[p_uid] = bal
            await bot.send_message(chat_id=chat_id, text=text)
            await cleanup_battle(battle_id, bot)
            return
            
        w_info = m_data["waves"][battle["current_wave"] - 1]
        mob = mobs_db.get(w_info["mob_id"], {"hp": 100})
        battle["mobs"] = [mob["hp"] for _ in range(w_info["count"])]
    else:
        battle["current_turn"] += 1
        if battle["current_turn"] > w_info["turns"]:
            battle["base_hp"] = round(battle["base_hp"] - sum(h/10 for h in battle["mobs"]), 2)
            battle["mobs"] = []
            if battle["base_hp"] <= 0:
                rew = m_data.get("rewards", {})
                text = "📛📛📛Поражение 📛📛📛\n"
                for k, v in rew.items():
                    amt = max(1, int(v * 0.1))
                    text += f"+{amt} {k}\n"
                    
                for p_uid in list(battle["players"].keys()):
                    bal = user_balances.get(p_uid, {"💰 Монеты": 100, "💎 Гемы": 0})
                    for k, v in rew.items(): 
                        amt = max(1, int(v * 0.1))
                        bal[k] = bal.get(k, 0) + amt
                    user_balances[p_uid] = bal
                await bot.send_message(chat_id=chat_id, text=text)
                await cleanup_battle(battle_id, bot)
                return
                
            battle["current_wave"] += 1
            battle["current_turn"] = 1
            if battle["current_wave"] > m_data["waves_total"]:
                rew = m_data.get("rewards", {})
                text = "❇️❇️❇️Победа❇️❇️❇️\n"
                for k, v in rew.items():
                    text += f"+{v} {k}\n"
                    
                for p_uid in list(battle["players"].keys()):
                    bal = user_balances.get(p_uid, {"💰 Монеты": 100, "💎 Гемы": 0})
                    for k, v in rew.items(): bal[k] = bal.get(k, 0) + v
                    user_balances[p_uid] = bal
                await bot.send_message(chat_id=chat_id, text=text)
                await cleanup_battle(battle_id, bot)
                return
                
            w_info = m_data["waves"][battle["current_wave"] - 1]
            mob = mobs_db.get(w_info["mob_id"], {"hp": 100})
            battle["mobs"] = [mob["hp"] for _ in range(w_info["count"])]

    photo_file, text, main_kb = render_battle_ui(battle_id)
    
    try:
        if photo_file:
            try: await bot.edit_message_media(chat_id=chat_id, message_id=battle["main_msg_id"], media=InputMediaPhoto(media=photo_file, caption=text[:1024], parse_mode="HTML"), reply_markup=main_kb)
            except: pass
        else:
            try: await bot.edit_message_caption(chat_id=chat_id, message_id=battle["main_msg_id"], caption=text[:1024], reply_markup=main_kb, parse_mode="HTML")
            except: 
                try: await bot.edit_message_text(chat_id=chat_id, message_id=battle["main_msg_id"], text=text[:4096], reply_markup=main_kb, parse_mode="HTML")
                except: pass
    except TelegramBadRequest: pass 

async def battle_ticker(battle_id: str, bot: Bot):
    try:
        while battle_id in active_battles:
            battle = active_battles[battle_id]
            delay = bot_settings["turn_time_skip"] if battle["auto_skip"] else bot_settings["turn_time_noskip"]
            await asyncio.sleep(delay)
            if battle_id in active_battles:
                await process_battle_turn(battle_id, bot)
    except asyncio.CancelledError:
        pass

@dp.callback_query(StateFilter('*'), F.data.startswith("b_dep_"))
async def cq_battle_deploy(callback: CallbackQuery, state: FSMContext):
    await state.clear()
    _, _, battle_id, unit_id = callback.data.split("_")
    user_id_str = str(callback.from_user.id)
    
    if battle_id not in active_battles: return await callback.answer("Бой окончен.", show_alert=True)
    battle = active_battles[battle_id]
    if user_id_str not in battle["players"]: return await callback.answer("Вы не участвуете в этом бою!", show_alert=True)
        
    u_data = units_db.get(unit_id)
    if not u_data: return await callback.answer("Юнит не найден!")
        
    p_data = battle["players"][user_id_str]
    cost = u_data.get("deploy_cost", 50)
    limit = u_data.get("supply_limit", 99)
    
    if sum(1 for u in p_data["deployed"] if u["uid"] == unit_id) >= limit: 
        return await callback.answer("🛑 Лимит достигнут!", show_alert=True)
    if p_data["coins"] < cost: 
        return await callback.answer("💰 Мало денег!", show_alert=True)
        
    p_data["coins"] -= cost
    p_data["deployed"].append({"uid": unit_id, "next_attack": battle["current_turn"], "time_bank": 0.0})
    
    new_kb = get_player_kb(battle_id, user_id_str)
    try: await callback.message.edit_reply_markup(reply_markup=new_kb)
    except TelegramBadRequest: pass
    
    photo_file, text, main_kb = render_battle_ui(battle_id)
    try:
        if photo_file:
            try: await callback.bot.edit_message_media(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], media=InputMediaPhoto(media=photo_file, caption=text[:1024], parse_mode="HTML"), reply_markup=main_kb)
            except: pass
        else:
            try: await callback.bot.edit_message_caption(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], caption=text[:1024], reply_markup=main_kb, parse_mode="HTML")
            except:
                try: await callback.bot.edit_message_text(chat_id=battle["chat_id"], message_id=battle["main_msg_id"], text=text[:4096], reply_markup=main_kb, parse_mode="HTML")
                except: pass
    except TelegramBadRequest: pass
    await callback.answer("Установлен!")

@dp.callback_query(StateFilter('*'), F.data.startswith("b_toggle_"))
async def cq_battle_toggle_skip(callback: CallbackQuery, state: FSMContext):
    await state.clear()
