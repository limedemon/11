@router.callback_query(F.data == "menu_inventory")
async def show_inv(call: CallbackQuery):
    user_id = call.from_user.id
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('''
            SELECT i.id, u.name, i.is_equipped FROM inventory i 
            JOIN units u ON i.unit_id = u.id WHERE i.user_id = ?
        ''', (user_id,)) as cur:
            items = await cur.fetchall()
            
    if not items: return await call.message.edit_text("Инвентарь пуст.", reply_markup=main_menu_kb())
        
    kb = [[InlineKeyboardButton(text=f"{n} | {'✅' if eq else '❌'}", callback_data=f"eq_{iid}")] for iid, n, eq in items]
    kb.append([InlineKeyboardButton(text="🔙 Назад", callback_data="cancel")])
    await call.message.edit_text("🎒 <b>Инвентарь:</b>\nЖми для экипировки (макс 5).", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb), parse_mode="HTML")

@router.callback_query(F.data.startswith("eq_"))
async def toggle_eq(call: CallbackQuery):
    inv_id = int(call.data.split("_")[1])
    user_id = call.from_user.id
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute('SELECT COUNT(*) FROM inventory WHERE user_id = ? AND is_equipped = 1', (user_id,)) as cur:
            count = (await cur.fetchone())[0]
        async with db.execute('SELECT is_equipped FROM inventory WHERE id = ?', (inv_id,)) as cur:
            is_eq = (await cur.fetchone())[0]
            
        if not is_eq and count >= 5:
            return await call.answer("❌ Максимум 5 юнитов!", show_alert=True)
            
        await db.execute('UPDATE inventory SET is_equipped = ? WHERE id = ?', (not is_eq, inv_id))
        await db.commit()
    await show_inv(call)

