def load_child_bots():
    if os.path.exists(CHILD_BOTS_FILE):
        try:
            with open(CHILD_BOTS_FILE, 'r', encoding='utf-8') as f:
                return json.load(f)
        except: pass
    return {}

def save_child_bot(token, owner_id):
    bots = load_child_bots()
    bots[token] = owner_id
    with open(CHILD_BOTS_FILE, 'w', encoding='utf-8') as f:
        json.dump(bots, f, ensure_ascii=False, indent=4)

def load_data():
    global admins_db, rarities_db, units_db, unit_id_counter, user_inventory, user_equipped
    global mobs_db, mob_id_counter, currencies_db, maps_db, map_id_counter
    global user_balances, crates_db, crate_id_counter, user_free_crate_times, bot_settings
    
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE, 'r', encoding='utf-8') as f:
                data = json.load(f)
                admins_db = set(data.get("admins_db", [MAIN_ADMIN_ID]))
                if MAIN_ADMIN_ID not in admins_db: admins_db.add(MAIN_ADMIN_ID)
                
                rarities_db = data.get("rarities_db", [])
                
                loaded_settings = data.get("bot_settings", {})
                bot_settings["coins_per_damage"] = loaded_settings.get("coins_per_damage", 0.5)
                bot_settings["turn_time_skip"] = loaded_settings.get("turn_time_skip", 5)
                bot_settings["turn_time_noskip"] = loaded_settings.get("turn_time_noskip", 10)
                
                loaded_units = data.get("units_db", {})
                for uid, udata in loaded_units.items():
                    if "deploy_cost" not in udata: udata["deploy_cost"] = 50
                    if "supply_limit" not in udata: udata["supply_limit"] = 99
                    if "name" not in udata: udata["name"] = f"Юнит №{uid}"
                    if "unit_type" not in udata: 
                        udata["unit_type"] = udata.get("attack_type", "Одиночный")
                    
                    if udata["unit_type"] == "Саппорт":
                        if "cd_boost" not in udata: udata["cd_boost"] = 1.0
                        if "dmg_boost" not in udata: udata["dmg_boost"] = 1.0
                    elif udata["unit_type"] == "Ферма":
                        if "income" not in udata: udata["income"] = 10
                    else:
                        if "cd" not in udata: udata["cd"] = 1.0
                        if "damage" not in udata: udata["damage"] = 10
                units_db = loaded_units
                unit_id_counter = data.get("unit_id_counter", 1)
                
                loaded_mobs = data.get("mobs_db", {})
                for mid, mdata in loaded_mobs.items():
                    if "name" not in mdata: mdata["name"] = f"Моб №{mid}"
                mobs_db = loaded_mobs
                mob_id_counter = data.get("mob_id_counter", 1)
                
                currencies_db = data.get("currencies_db", ["💰 Монеты", "💎 Гемы"])
                if "💰 Монеты" not in currencies_db: currencies_db.insert(0, "💰 Монеты")
                
                loaded_maps = data.get("maps_db", {})
                for mid, mdata in loaded_maps.items():
                    if "name" not in mdata: mdata["name"] = f"Карта №{mid}"
                    if "starting_coins" not in mdata: mdata["starting_coins"] = 100
                    if "photo" not in mdata: mdata["photo"] = None
                maps_db = loaded_maps
                map_id_counter = data.get("map_id_counter", 1)
                
                loaded_crates = data.get("crates_db", {})
                for cid, cdata in loaded_crates.items():
                    if "name" not in cdata: cdata["name"] = f"Крейт №{cid}"
                    if "currency" not in cdata: cdata["currency"] = "💰 Монеты"
                crates_db = loaded_crates
                crate_id_counter = data.get("crate_id_counter", 1)
                
                loaded_inv = data.get("user_inventory", {})
                user_inventory = {str(k): set(v) for k, v in loaded_inv.items()}
                loaded_eq = data.get("user_equipped", {})
                user_equipped = {str(k): list(v) for k, v in loaded_eq.items()}
                
                loaded_bals = data.get("user_balances", {})
                for uid, bal in loaded_bals.items():
                    if "coins" in bal: bal["💰 Монеты"] = bal.pop("coins")
                    if "gems" in bal: bal["💎 Гемы"] = bal.pop("gems")
                user_balances = loaded_bals
                
                loaded_free_crates = data.get("user_free_crate_times", {})
                user_free_crate_times = {str(k): float(v) for k, v in loaded_free_crates.items()}
                
                logging.info(f"✅ Данные успешно загружены из {DATA_FILE}.")
        except Exception as e:
            logging.error(f"⚠️ Ошибка загрузки: {e}")

def save_data():
    try:
        data = {
            "admins_db": list(admins_db),
            "rarities_db": rarities_db,
            "units_db": units_db,
            "unit_id_counter": unit_id_counter,
            "mobs_db": mobs_db,
            "mob_id_counter": mob_id_counter,
            "currencies_db": currencies_db,
            "maps_db": maps_db,
            "map_id_counter": map_id_counter,
            "crates_db": crates_db,
            "crate_id_counter": crate_id_counter,
            "user_inventory": {str(k): list(v) for k, v in user_inventory.items()},
            "user_equipped": {str(k): list(v) for k, v in user_equipped.items()},
            "user_balances": user_balances,
            "user_free_crate_times": user_free_crate_times,
            "bot_settings": bot_settings
        }
        with open(DATA_FILE, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=4)
    except Exception as e:
        logging.error(f"⚠️ Ошибка сохранения: {e}")

# ==========================================
# MIDDLEWARE ДЛЯ ПАНЕЛИ
# ==========================================
class PanelMiddleware(BaseMiddleware):
    async def __call__(self, handler, event, data):
        if isinstance(event, CallbackQuery) and event.message:
            if event.message.chat.type in {"group", "supergroup"}:
                public_cb = ["el_", "b_dep_", "b_toggle_", "b_surr_"]
                if not any(event.data.startswith(p) for p in public_cb):
                    key = f"{event.message.chat.id}_{event.message.message_id}"
                    if key in panel_owners and panel_owners[key] != event.from_user.id:
                        await event.answer("🚫 Это меню вызвал другой игрок! Напишите /panel", show_alert=True)
                        return
        return await handler(event, data)

