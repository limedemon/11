@dp.callback_query(AdminCrateAdd.unit_select, F.data.startswith("selcrateunit_"))
async def crate_step_5_unit(callback: CallbackQuery, state: FSMContext):
    act = callback.data.split("_")[1]
    if act == "finish":
        data = await state.get_data()
        if not data["temp_units"]: return await callback.answer("⚠️ Крейт пуст!", show_alert=True)
        global crate_id_counter
        cid = str(crate_id_counter)
        crates_db[cid] = {"photo": data["photo"], "name": data["name"], "currency": data["currency"], "price": data["price"], "units": data["temp_units"]}
        crate_id_counter += 1
        await state.clear()
        try: await callback.message.delete()
        except: pass
        await send_main_screen(callback.message, f"✅ Крейт «{data['name']}» создан!")
        return await callback.answer()
        
    await state.update_data(temp_uid=act)
    await state.set_state(AdminCrateAdd.unit_weight)
    await callback.message.edit_text(f"⚖️ Вес для {units_db[act].get('name')} (0.000001 - 99):")
    await callback.answer()

@dp.message(AdminCrateAdd.unit_weight)
async def crate_step_6_weight(message: Message, state: FSMContext):
    try: weight = float(message.text.replace(",", "."))
    except: return await message.answer("⚠️ Ошибка. Введите число.")
    data = await state.get_data()
    data["temp_units"][data["temp_uid"]] = weight
    await state.update_data(temp_units=data["temp_units"])
    await state.set_state(AdminCrateAdd.unit_select)
    kb = [[InlineKeyboardButton(text=f"🔸{u.get('name', f'Юнит №{uid}')}🔸", callback_data=f"selcrateunit_{uid}")] for uid, u in units_db.items()]
    kb.append([InlineKeyboardButton(text="✅Сохранить✅", callback_data="selcrateunit_finish")])
    await message.answer("✅ Добавлен. Еще?", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))

