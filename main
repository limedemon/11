import sys
import subprocess
import os

# ==========================================
# 🚀 АВТОМАТИЧЕСКАЯ УСТАНОВКА БИБЛИОТЕК
# ==========================================
# Этот блок должен быть в самом начале, ДО импорта aiogram и aiosqlite
def auto_install_packages():
    try:
        import aiogram
        import aiosqlite
    except ImportError:
        print("⏳ Внимание: Библиотеки aiogram или aiosqlite не найдены.")
        print("⏳ Начинаю автоматическую установку (это займет около минуты)...")
        try:
            # Запускаем pip install через системный вызов
            subprocess.check_call([sys.executable, "-m", "pip", "install", "aiogram==3.4.1", "aiosqlite"])
            print("✅ Библиотеки успешно установлены! Запускаю бота...")
        except Exception as e:
            print(f"❌ Критическая ошибка при установке: {e}")
            sys.exit(1)

# Вызываем автоустановку перед основным кодом
auto_install_packages()

